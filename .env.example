# Base URL for the local Ollama server.
OLLAMA_HOST=http://localhost:11434

# Ollama model name used for local inference.
OLLAMA_MODEL=llama3.1:8b

# faster-whisper model size used for transcription.
WHISPER_MODEL=medium

# Beam size used by faster-whisper transcription.
WHISPER_BEAM_SIZE=5

# Redis connection URL used for vector search/cache services.
REDIS_URL=redis://localhost:6379

# Number of retrieved results used for each query.
RETRIEVAL_TOP_K=5

# Minimum retrieval score threshold (0.0 to 1.0)
MIN_RETRIEVAL_SCORE=0.4

# Target transcript chunk size in words for text embedding.
CHUNK_SIZE=250

# Number of transcript segments to overlap between text chunks.
CHUNK_OVERLAP=2

# Minimum mean brightness required to keep a sampled frame.
BRIGHTNESS_THRESHOLD=10.0

# Minimum Canny edge density used to infer slide/text content.
TEXT_EDGE_THRESHOLD=500.0

# Maximum perceptual-hash distance for consecutive frames to count as duplicates.
DUPLICATE_THRESHOLD=8

# Session time-to-live in seconds.
SESSION_TTL=3600

# Allow duplicate OpenMP runtime loading on Windows.
KMP_DUPLICATE_LIB_OK=TRUE

# Disable Hugging Face Hub symlink warnings on Windows.
HF_HUB_DISABLE_SYMLINKS_WARNING=1

# Disable tokenizer worker parallelism to avoid noisy runtime warnings.
TOKENIZERS_PARALLELISM=false

# Compute device used by local models, such as cpu or cuda.
DEVICE=cpu
